# ========================================
# Job Hunting Agent — Configuration
# ========================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# --- Server ---
HOST=0.0.0.0
PORT=5000
DEBUG=false
SECRET_KEY=change-this-to-a-random-string

# --- マイナビ ---
# Graduation year suffix (e.g. 27 = マイナビ2027/2027年卒)
MYNAVI_YEAR=27
MYNAVI_EMAIL=your_email@example.com
MYNAVI_PASSWORD=your_password

# --- Gmail ---
# Set to true after placing credentials.json in project root
GMAIL_ENABLED=false
# Port for OAuth2 redirect (change if 8090 is in use)
GMAIL_OAUTH_PORT=8090

# --- Scheduler ---
# Morning alert time (deadline & interview reminders)
MORNING_ALERT_HOUR=7
MORNING_ALERT_MINUTE=0
# Scraping times
SCRAPE_MORNING_HOUR=8
SCRAPE_MORNING_MINUTE=30
SCRAPE_EVENING_HOUR=18
SCRAPE_EVENING_MINUTE=30
# Gmail check interval
EMAIL_CHECK_INTERVAL_MINUTES=30
TIMEZONE=Asia/Tokyo

# --- AI (必須: 少なくとも1つ設定) ---
# Provider: deepseek or gemini
AI_PROVIDER=deepseek
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Alternative: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Browser Automation ---
# Set to false to see browser window during scraping (debug)
HEADLESS=true
BROWSER_LOCALE=ja-JP
